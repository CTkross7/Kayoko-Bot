# 카요코 봇 - 환경변수 예시 파일
# 이 파일을 .env 로 복사한 뒤 실제 값을 채워 넣으세요.
# .env 자체는 반드시 .gitignore 에 포함해서 저장소에 커밋되지 않게 하세요.

# ── Discord 봇 토큰 ──
# BOT_ENV=test 이면 DISCORD_TEST_TOKEN, 아니면 DISCORD_BOT_TOKEN 사용
BOT_ENV=test
DISCORD_TEST_TOKEN=
DISCORD_BOT_TOKEN=
# 위 둘 대신 바로 이 값을 쓰고 싶으면 지정 (선택)
# BOT_TOKEN=

# ── Gemini API 키 (쉼표로 여러 개 구분, 로테이션용) ──
GOOGLE_API_KEYS=key1,key2,key3

# ── 디스호스트 API ──
DISHOST_API_KEY=
DISHOST_API_URL=https://listapi.dishost.kr

# ── Discord 웹훅 URL ──
ADMIN_WEBHOOK_URL=
REPORT_WEBHOOK_URL=
WELCOME_WEBHOOK_URL=
RARE_CATCH_WEBHOOK_URL=
# 지정하지 않으면 ADMIN_WEBHOOK_URL 값을 그대로 사용합니다.
ANTICHEAT_WEBHOOK_URL=
